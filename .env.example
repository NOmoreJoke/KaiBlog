# ──────────────────────────────────────
# Server
# ──────────────────────────────────────
NODE_ENV=development
PORT=3000

# ──────────────────────────────────────
# Supabase
# ──────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────
# AI (server-side only, never exposed to client)
# ──────────────────────────────────────
GLM_API_KEY=
OPENROUTER_API_KEY=

# ──────────────────────────────────────
# Podcast sync (optional)
# ──────────────────────────────────────
XIAOYUZHOU_MCP_URL=

# ──────────────────────────────────────
# Auth
# ──────────────────────────────────────
ADMIN_ALLOWED_EMAILS=
SESSION_SECRET=

# ──────────────────────────────────────
# Site metadata
# ──────────────────────────────────────
SITE_NAME=KaiBlog
SITE_URL=https://example.com
